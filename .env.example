# Local/off-AWS placeholder environment.
# Fill values locally. Do not commit real secrets.

APP_ENV=local
PORT=8000
FRONTEND_API_BASE_URL=http://localhost:8000

# Local mode should not require AWS credentials.
AWS_REGION=ap-northeast-2
AGENT_RUNTIME=v2
LOCAL_MODE=true
DISABLE_AWS_CALLS=true

# Prediction local substitutes
PREDICT_MODE=local_or_degraded
MODEL_ARTIFACT_DIR=/path/to/private-backup/model

# RAG local substitutes
RAG_MODE=local
RAG_SOURCE_DIR=/path/to/RAG_PDF
VECTOR_STORE=faiss_or_chroma_or_local_opensearch

# DDI local substitutes
DDI_MODE=local_or_degraded
DDI_DATA_DIR=/path/to/private-backup/ddi

# LLM provider placeholders; never commit real values.
LLM_PROVIDER=local_or_external
LLM_API_KEY=<set-in-private-env>
